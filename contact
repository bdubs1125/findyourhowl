                className="bg-amber px-8 py-4 text-sm font-bold uppercase tracking-widest text-pine hover:scale-[1.02]"
              >
                Send up the howl
              </button>
            </form>
          )}
        </div>
      </section>
      <SiteFooter />
    </main>
  );
}
function Field({
  label,
  name,
  type = "text",
  required,
}: {
  label: string;
  name: string;
  type?: string;
  required?: boolean;
}) {
  return (
    <div>
      <label className="mb-2 block text-xs font-semibold uppercase tracking-[0.25em] text-mist">
        {label}
      </label>
      <input
        name={name}
        type={type}
        required={required}
        className="w-full border border-sage/30 bg-pine px-4 py-3 text-bone placeholder:text-mist/50 focus:border-amber focus:outline-none"
      />
    </div>
  );
}
